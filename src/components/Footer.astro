---
import { SOCIAL_LINKS } from '@/consts'

// Inline SVG paths — small set, no new icon-set dependency.
const ICON_PATH: Record<string, string> = {
  x: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  github:
    'M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.9.58.11.79-.25.79-.56v-2.07c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.95 10.95 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z',
  scholar:
    'M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z',
}
---

<footer class="mt-16 bg-[color:var(--color-bg-dark)] text-white/75">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-6 px-6 py-10 text-sm">
    <div>
      <div class="text-base font-semibold text-white">The Fiete Lab</div>
      <div class="mt-1">
        MIT Department of Brain and Cognitive Sciences<br />
        Building 46, Suite 5065 · 43 Vassar St., Cambridge, MA 02139
      </div>
    </div>
    <div class="flex items-center gap-5">
      <a href="/contact" class="text-[color:#cfe0ff] hover:text-white">Contact</a>
      {
        SOCIAL_LINKS.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={s.label}
            title={s.label}
            class="text-[color:#cfe0ff] transition hover:text-white"
          >
            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={ICON_PATH[s.icon] ?? ''} />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</footer>
