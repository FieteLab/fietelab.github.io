---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  person: CollectionEntry<'people'>
  size?: 'sm' | 'md' | 'lg'
  /** When true, render as a link to /people/<slug>. Default true. */
  link?: boolean
}

const { person, size = 'md', link = true } = Astro.props
const data = person.data

const sizeMap = {
  sm: { wrapper: 'p-4', avatar: 'h-20 w-20', name: 'text-base' },
  md: { wrapper: 'p-5', avatar: 'h-28 w-28', name: 'text-lg' },
  lg: { wrapper: 'p-6', avatar: 'h-40 w-40', name: 'text-xl' },
} as const
const s = sizeMap[size]

const initials = data.name
  .split(/\s+/)
  .filter(Boolean)
  .map((p) => p[0])
  .slice(0, 2)
  .join('')
  .toUpperCase()

const Tag = link ? 'a' : 'article'
const linkProps = link ? { href: `/people/${person.id}/` } : {}
---

<Tag
  {...linkProps}
  class={`group flex flex-col items-start gap-3 rounded-xl border border-[color:var(--color-border)] bg-white ${s.wrapper} no-underline transition hover:no-underline hover:-translate-y-0.5 hover:shadow-md ${link ? 'cursor-pointer' : ''}`}
>
  <div class={`relative ${s.avatar} overflow-hidden rounded-full bg-gradient-to-br from-[color:var(--color-accent)] to-[color:var(--color-accent-soft)] text-white`}>
    {
      data.avatar ? (
        <Image
          src={data.avatar}
          alt={data.name}
          width={300}
          height={300}
          class="h-full w-full object-cover"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-2xl font-semibold">
          {initials}
        </div>
      )
    }
  </div>
  <div class="flex flex-col gap-1">
    <h3 class={`${s.name} font-semibold leading-tight text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)]`}>
      {data.name}
    </h3>
    <div class="text-xs font-semibold text-[color:var(--color-accent)]">
      {data.title}{data.coAdvisor && <span class="font-normal text-[color:var(--color-text-soft)]"> · w/ {data.coAdvisor}</span>}
    </div>
    {
      !link && (
        <div class="mt-1 flex flex-wrap gap-3 text-xs">
          {data.website && <a href={data.website} target="_blank" rel="noopener">website</a>}
          {data.email && <a href={`mailto:${data.email}`}>email</a>}
          {data.scholar && <a href={data.scholar} target="_blank" rel="noopener">scholar</a>}
          {data.github && <a href={data.github} target="_blank" rel="noopener">github</a>}
        </div>
      )
    }
  </div>
</Tag>
