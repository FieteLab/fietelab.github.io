---
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import { getPublicationsByPerson, formatAuthors } from '@/lib/data'
import { topicColor } from '@/lib/topics'

export async function getStaticPaths() {
  const people = await getCollection('people')
  return people.map((person) => ({
    params: { id: person.id },
    props: { person },
  }))
}

interface Props {
  person: CollectionEntry<'people'>
}

const { person } = Astro.props
const data = person.data
const { Content } = await render(person)
const personPubs = await getPublicationsByPerson(person)

function linkLabel(link?: string) {
  if (!link) return null
  if (/arxiv\.org/.test(link)) return 'arXiv'
  if (/biorxiv\.org/.test(link)) return 'bioRxiv'
  if (/openreview\.net/.test(link)) return 'OpenReview'
  if (
    /(nature|elifesciences|cell\.com|sciencedirect|nih|pnas|aps\.org|annualreviews|nips|neurips|mlr\.press|proceedings|sfn)/.test(
      link,
    )
  )
    return 'Journal'
  return 'Link'
}

const initials = data.name
  .split(/\s+/)
  .filter(Boolean)
  .map((p) => p[0])
  .slice(0, 2)
  .join('')
  .toUpperCase()
---

<Layout title={data.name} description={`Profile of ${data.name}, ${data.title} in the Fiete Lab at MIT.`}>
  <section class="mx-auto max-w-4xl px-6 py-10">
    <a
      href="/people/"
      class="inline-flex items-center gap-1 text-sm text-[color:var(--color-text-soft)] hover:text-[color:var(--color-accent)] no-underline hover:no-underline"
    >
      <span aria-hidden="true">&larr;</span> All people
    </a>

    <header class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-[200px_1fr] sm:items-start">
      <div class="relative h-48 w-48 overflow-hidden rounded-2xl bg-gradient-to-br from-[color:var(--color-accent)] to-[color:var(--color-accent-soft)] text-white">
        {
          data.avatar ? (
            <Image
              src={data.avatar}
              alt={data.name}
              width={400}
              height={400}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center text-5xl font-semibold">
              {initials}
            </div>
          )
        }
      </div>

      <div class="flex flex-col gap-2">
        <div class="text-xs font-semibold uppercase tracking-wide text-[color:var(--color-text-soft)]">
          {data.role}
        </div>
        <h1 class="text-3xl font-semibold leading-tight">{data.name}</h1>
        <div class="text-sm font-medium text-[color:var(--color-accent)]">
          {data.title}{data.coAdvisor && <span class="font-normal text-[color:var(--color-text-soft)]"> · co-advised with {data.coAdvisor}</span>}
        </div>
        <div class="mt-2 flex flex-wrap gap-2 text-xs">
          {data.website && (
            <a href={data.website} target="_blank" rel="noopener" class="rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1">
              Website
            </a>
          )}
          {data.email && (
            <a href={`mailto:${data.email}`} class="rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1">
              Email
            </a>
          )}
          {data.scholar && (
            <a href={data.scholar} target="_blank" rel="noopener" class="rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1">
              Google Scholar
            </a>
          )}
          {data.github && (
            <a href={data.github} target="_blank" rel="noopener" class="rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1">
              GitHub
            </a>
          )}
          {data.linkedin && (
            <a href={data.linkedin} target="_blank" rel="noopener" class="rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1">
              LinkedIn
            </a>
          )}
        </div>
      </div>
    </header>

    <article class="prose-bio mt-10 max-w-2xl text-[color:var(--color-text-muted)]">
      <Content />
    </article>

    {personPubs.length > 0 && (
      <section class="mt-16">
        <div class="flex items-baseline justify-between gap-3">
          <h2 class="text-xl font-semibold">
            Publications ({personPubs.length})
          </h2>
          <a
            href="/publications/"
            class="text-xs text-[color:var(--color-text-soft)] hover:text-[color:var(--color-accent)]"
          >
            All lab papers &rarr;
          </a>
        </div>
        <p class="mt-1 text-xs text-[color:var(--color-text-soft)]">
          Auto-detected by matching {data.name} against author lists. If a
          paper is missing or extra, edit
          <code>authorAliases</code> in
          <code>src/content/people/{person.id}.md</code>.
        </p>
        <ul class="mt-4 divide-y divide-[color:var(--color-border)]">
          {personPubs.map((pub) => {
            const link = pub.data.link
            const label = linkLabel(link)
            const pubTopics = pub.data.topics ?? []
            return (
              <li class="py-3">
                <div class="font-medium leading-snug">
                  {link ? (
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener"
                      class="text-[color:var(--color-text)] no-underline hover:text-[color:var(--color-accent)] hover:underline"
                    >
                      {pub.data.title}
                    </a>
                  ) : (
                    <span class="text-[color:var(--color-text)]">
                      {pub.data.title}
                    </span>
                  )}
                </div>
                <div class="mt-1 text-xs text-[color:var(--color-text-muted)]">
                  {formatAuthors(pub.data.authors)}
                </div>
                <div class="mt-1.5 flex flex-wrap items-center gap-2 text-xs">
                  <span class="font-semibold text-[color:var(--color-accent)]">
                    {pub.data.venue} · {pub.data.year}
                  </span>
                  {pubTopics.map((t) => {
                    const c = topicColor(t)
                    return (
                      <a
                        href={`/publications/#${encodeURIComponent(t)}`}
                        class="inline-flex items-center rounded-full border px-2 py-0.5 font-medium no-underline transition hover:brightness-95 hover:no-underline"
                        style={`background:${c.bg};color:${c.text};border-color:${c.ring}`}
                      >
                        {t}
                      </a>
                    )
                  })}
                  {link && (
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener"
                      class="ml-auto inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] bg-white px-2.5 py-0.5 text-[color:var(--color-link)] no-underline hover:bg-[color:var(--color-bg-alt)] hover:no-underline"
                    >
                      {label} <span aria-hidden="true">↗</span>
                    </a>
                  )}
                </div>
              </li>
            )
          })}
        </ul>
      </section>
    )}
  </section>
</Layout>
