---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { topicColor, TOPIC_ORDER } from '@/lib/topics'
import { isRedundantCitation, getAuthorLinkMap } from '@/lib/data'
import AuthorList from '@/components/AuthorList.astro'

const allPubs = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year,
)
const linkMap = await getAuthorLinkMap()
const presentTopics = new Set<string>()
for (const p of allPubs) {
  for (const t of p.data.topics ?? []) presentTopics.add(t)
}
const topics = TOPIC_ORDER.filter((t) => presentTopics.has(t))
const topicCount = (t: string) =>
  allPubs.filter((p) => (p.data.topics ?? []).includes(t)).length

// Short label for the link badge
function linkLabel(link?: string) {
  if (!link) return null
  if (/arxiv\.org/.test(link)) return 'arXiv'
  if (/biorxiv\.org/.test(link)) return 'bioRxiv'
  if (/openreview\.net/.test(link)) return 'OpenReview'
  if (
    /(nature|elifesciences|cell\.com|sciencedirect|nih|pnas|aps\.org|annualreviews|nips|neurips|mlr\.press|proceedings|sfn)/.test(
      link,
    )
  )
    return 'Journal'
  return 'Link'
}

// Group by year for default view
const byYear = new Map<number, typeof allPubs>()
for (const p of allPubs) {
  if (!byYear.has(p.data.year)) byYear.set(p.data.year, [])
  byYear.get(p.data.year)!.push(p)
}
const years = [...byYear.keys()].sort((a, b) => b - a)

// Year filter: each of the 5 most recent years individually,
// then "Earlier" rolls everything older into one bucket.
const RECENT_N = 5
const recentYears = years.slice(0, RECENT_N).filter((y) => (byYear.get(y)?.length ?? 0) > 0)
const earlierYears = years.slice(RECENT_N)
const earlierCount = earlierYears.reduce((n, y) => n + (byYear.get(y)?.length ?? 0), 0)
const earliestYear = earlierYears.length ? Math.min(...earlierYears) : 0
const latestEarlier = earlierYears.length ? Math.max(...earlierYears) : 0
---

<Layout title="Papers">
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="text-3xl font-semibold">Papers</h1>
    <p class="mt-2 max-w-2xl text-[color:var(--color-text-muted)]">
      All publications and preprints from the lab. For citation counts and
      complete coverage, see
      <a
        href="https://scholar.google.com/citations?user=uE-CihIAAAAJ"
        target="_blank"
        rel="noopener">Google Scholar</a
      >.
    </p>

    <!-- Topic filter -->
    <div class="mt-8 flex flex-wrap items-center gap-2" id="topic-filter">
      <span class="mr-1 w-16 shrink-0 text-xs font-semibold uppercase tracking-wide text-[color:var(--color-text-soft)]">
        Topic:
      </span>
      <button
        type="button"
        data-topic="__all"
        class="topic-pill rounded-full border border-[color:var(--color-accent)] bg-[color:var(--color-accent)] px-3 py-1 text-xs font-medium text-white transition"
        aria-pressed="true"
      >
        All ({allPubs.length})
      </button>
      {
        topics.map((t) => {
          const c = topicColor(t)
          return (
            <button
              type="button"
              data-topic={t}
              data-color-bg={c.bg}
              data-color-text={c.text}
              data-color-ring={c.ring}
              class="topic-pill rounded-full border px-3 py-1 text-xs font-medium transition"
              style={`background:${c.bg};color:${c.text};border-color:${c.ring}`}
              aria-pressed="false"
            >
              {t} ({topicCount(t)})
            </button>
          )
        })
      }
    </div>

    <!-- Year filter -->
    <div class="mt-3 flex flex-wrap items-center gap-2" id="year-filter">
      <span class="mr-1 w-16 shrink-0 text-xs font-semibold uppercase tracking-wide text-[color:var(--color-text-soft)]">
        Year:
      </span>
      <button
        type="button"
        data-year="__all"
        class="year-pill rounded-full border border-[color:var(--color-accent)] bg-[color:var(--color-accent)] px-3 py-1 text-xs font-medium text-white transition"
        aria-pressed="true"
      >
        All ({allPubs.length})
      </button>
      {
        recentYears.map((y) => (
          <button
            type="button"
            data-year={String(y)}
            class="year-pill rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1 text-xs font-medium text-[color:var(--color-text)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
            aria-pressed="false"
          >
            {y} ({byYear.get(y)!.length})
          </button>
        ))
      }
      {earlierCount > 0 && (
        <button
          type="button"
          data-year="__earlier"
          class="year-pill rounded-full border border-[color:var(--color-border)] bg-white px-3 py-1 text-xs font-medium text-[color:var(--color-text)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          aria-pressed="false"
        >
          {earliestYear}–{latestEarlier} ({earlierCount})
        </button>
      )}
    </div>

    {
      years.map((year) => (
        <div class="year-section mt-12" data-year={year}>
          <h2 class="border-b border-[color:var(--color-border)] pb-2 text-xl font-semibold">
            {year}
          </h2>
          <ul class="divide-y divide-[color:var(--color-border)]">
            {byYear.get(year)!.map((pub) => {
              const link = pub.data.link
              const label = linkLabel(link)
              const pubTopics = pub.data.topics ?? []
              const showCitation =
                pub.data.citation &&
                !isRedundantCitation(pub.data.citation, pub.data.venue, pub.data.year)
              return (
                <li
                  class="pub-item py-4"
                  data-topics={JSON.stringify(pubTopics)}
                >
                  <div class="font-medium leading-snug">
                    {link ? (
                      <a
                        href={link}
                        target="_blank"
                        rel="noopener"
                        class="text-[color:var(--color-text)] no-underline hover:text-[color:var(--color-accent)] hover:underline"
                      >
                        {pub.data.title}
                      </a>
                    ) : (
                      <span class="text-[color:var(--color-text)]">
                        {pub.data.title}
                      </span>
                    )}
                  </div>
                  <div class="mt-1 text-sm text-[color:var(--color-text-muted)]">
                    <AuthorList authors={pub.data.authors} linkMap={linkMap} />
                  </div>
                  <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                    <span class="font-semibold text-[color:var(--color-accent)]">
                      {pub.data.venue}
                    </span>
                    {showCitation && (
                      <span class="italic text-[color:var(--color-text-soft)]">
                        · {pub.data.citation}
                      </span>
                    )}
                    {pub.data.annotation && (
                      <span class="font-medium text-[color:var(--color-text-muted)]">
                        · {pub.data.annotation}
                      </span>
                    )}
                    {pubTopics.map((t) => {
                      const c = topicColor(t)
                      return (
                        <button
                          type="button"
                          data-topic-tag={t}
                          class="topic-tag inline-flex items-center rounded-full border px-2 py-0.5 font-medium transition hover:brightness-95"
                          style={`background:${c.bg};color:${c.text};border-color:${c.ring}`}
                        >
                          {t}
                        </button>
                      )
                    })}
                    {link && (
                      <a
                        href={link}
                        target="_blank"
                        rel="noopener"
                        class="ml-auto inline-flex items-center gap-1 rounded-full border border-[color:var(--color-border)] bg-white px-2.5 py-0.5 text-[color:var(--color-link)] no-underline hover:bg-[color:var(--color-bg-alt)] hover:no-underline"
                      >
                        {label} <span aria-hidden="true">↗</span>
                      </a>
                    )}
                  </div>
                </li>
              )
            })}
          </ul>
        </div>
      ))
    }

    <div
      id="empty-state"
      class="mt-12 hidden rounded-lg border border-dashed border-[color:var(--color-border)] bg-[color:var(--color-bg-alt)] p-8 text-center text-sm text-[color:var(--color-text-soft)]"
    >
      No papers tagged with this topic.
    </div>
  </section>
</Layout>

<script>
  const filterBar = document.getElementById('topic-filter')
  const topicPills = document.querySelectorAll<HTMLButtonElement>('.topic-pill')
  const yearPills = document.querySelectorAll<HTMLButtonElement>('.year-pill')
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.topic-tag')
  const items = document.querySelectorAll<HTMLLIElement>('.pub-item')
  const yearSections = document.querySelectorAll<HTMLDivElement>('.year-section')
  const emptyState = document.getElementById('empty-state')

  let activeTopic = '__all'
  let activeYear = '__all' // '__all' | '__earlier' | a 4-digit year string

  // Read every section's data-year once so we can resolve "earlier" quickly.
  const allYears = [...yearSections].map((s) => Number(s.dataset.year))
  const RECENT_N = 5
  const recentSet = new Set(
    [...allYears].sort((a, b) => b - a).slice(0, RECENT_N).map(String),
  )

  function styleTopicPill(p: HTMLButtonElement, isActive: boolean) {
    p.setAttribute('aria-pressed', String(isActive))
    if (p.dataset.topic === '__all') {
      p.style.background = isActive ? 'var(--color-accent)' : '#fff'
      p.style.color = isActive ? '#fff' : 'var(--color-text)'
      p.style.borderColor = isActive ? 'var(--color-accent)' : 'var(--color-border)'
      p.style.opacity = '1'
    } else {
      p.style.opacity = isActive ? '1' : '0.55'
      p.style.boxShadow = isActive
        ? `inset 0 0 0 2px ${p.dataset.colorText}`
        : 'none'
    }
  }

  function styleYearPill(p: HTMLButtonElement, isActive: boolean) {
    p.setAttribute('aria-pressed', String(isActive))
    p.style.background = isActive ? 'var(--color-accent)' : '#fff'
    p.style.color = isActive ? '#fff' : 'var(--color-text)'
    p.style.borderColor = isActive ? 'var(--color-accent)' : 'var(--color-border)'
  }

  function setActiveTopic(topic: string) {
    activeTopic = topic
    topicPills.forEach((p) => styleTopicPill(p, p.dataset.topic === topic))
  }

  function setActiveYear(year: string) {
    activeYear = year
    yearPills.forEach((p) => styleYearPill(p, p.dataset.year === year))
  }

  function applyFilter() {
    let visibleCount = 0
    items.forEach((item) => {
      const topics: string[] = JSON.parse(item.dataset.topics || '[]')
      const passesTopic = activeTopic === '__all' || topics.includes(activeTopic)
      // Year section parent contains the year; walk up to find it
      const sec = item.closest<HTMLDivElement>('.year-section')
      const itemYear = sec?.dataset.year || ''
      const passesYear =
        activeYear === '__all' ||
        (activeYear === '__earlier' ? !recentSet.has(itemYear) : itemYear === activeYear)
      const show = passesTopic && passesYear
      item.style.display = show ? '' : 'none'
      if (show) visibleCount++
    })
    yearSections.forEach((sec) => {
      let visibleInYear = 0
      sec.querySelectorAll<HTMLLIElement>('.pub-item').forEach((it) => {
        if (it.style.display !== 'none') visibleInYear++
      })
      sec.style.display = visibleInYear > 0 ? '' : 'none'
    })
    emptyState?.classList.toggle('hidden', visibleCount > 0)
    syncHash()
  }

  function syncHash() {
    const parts: string[] = []
    if (activeTopic !== '__all') parts.push('topic=' + encodeURIComponent(activeTopic))
    if (activeYear !== '__all') parts.push('year=' + encodeURIComponent(activeYear))
    if (parts.length === 0) {
      history.replaceState(null, '', location.pathname + location.search)
    } else {
      history.replaceState(null, '', '#' + parts.join('&'))
    }
  }

  topicPills.forEach((p) => {
    p.addEventListener('click', () => {
      setActiveTopic(p.dataset.topic || '__all')
      applyFilter()
      window.scrollTo({ top: filterBar?.offsetTop ?? 0, behavior: 'smooth' })
    })
  })
  yearPills.forEach((p) => {
    p.addEventListener('click', () => {
      setActiveYear(p.dataset.year || '__all')
      applyFilter()
      window.scrollTo({ top: filterBar?.offsetTop ?? 0, behavior: 'smooth' })
    })
  })
  tagButtons.forEach((b) => {
    b.addEventListener('click', () => {
      setActiveTopic(b.dataset.topicTag || '__all')
      applyFilter()
      window.scrollTo({ top: filterBar?.offsetTop ?? 0, behavior: 'smooth' })
    })
  })

  // Honor URL hash on load. Supports both "#Memory" (legacy bare-topic
  // links) and "#topic=Memory&year=2024".
  const raw = location.hash.slice(1)
  if (raw) {
    if (raw.includes('=')) {
      const params = new URLSearchParams(raw)
      const t = params.get('topic')
      const y = params.get('year')
      if (t) setActiveTopic(t)
      if (y) setActiveYear(y)
    } else {
      setActiveTopic(decodeURIComponent(raw))
    }
    applyFilter()
  }
</script>
