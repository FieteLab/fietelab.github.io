---
import Layout from '@/layouts/Layout.astro'
import { getEntry } from 'astro:content'

const contact = await getEntry('site', 'contact')
const intro = contact?.data.intro ?? 'Get in touch with the lab.'
const cards = contact?.data.cards ?? []
---

<Layout title="Contact">
  <section class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-semibold">Contact</h1>
    <p class="mt-2 max-w-2xl text-[color:var(--color-text-muted)]">{intro}</p>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        cards.map((card) => (
          <div class="rounded-xl border border-[color:var(--color-border)] bg-white p-6">
            <h2 class="text-base font-semibold text-[color:var(--color-accent)]">
              {card.title}
            </h2>
            <p
              class="mt-2 text-sm text-[color:var(--color-text-muted)]"
              set:html={card.body}
            />
          </div>
        ))
      }
    </div>
  </section>
</Layout>
