---
import Layout from '@/layouts/Layout.astro'
import PersonCard from '@/components/PersonCard.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { getAllPeople } from '@/lib/data'
import { AFFILIATIONS } from '@/consts'

const allPeople = await getAllPeople()
const pi = allPeople.find((p) => p.data.role === 'PI')
const newsItems = await getCollection('news')
newsItems.sort((a, b) => b.data.date.localeCompare(a.data.date))

const home = await getEntry('site', 'home')
const { Content: HomeAbout } = home ? await render(home) : { Content: null }
const heroTitle = home?.data.heroTitle ?? 'The Fiete Lab'
const heroTagline =
  home?.data.heroTagline ??
  'Our goal is to better understand the dynamics and coding principles that underlie computation in the brain.'
const exploreCards = home?.data.exploreCards ?? []
---

<Layout>
  <!-- Hero -->
  <section
    class="relative overflow-hidden py-24 text-white"
    style="background: linear-gradient(135deg, #14060c 0%, #45091c 55%, #8a1538 100%);"
  >
    <div
      class="absolute inset-0 opacity-80"
      style="background:
        radial-gradient(circle at 18% 22%, rgba(196,69,112,.32), transparent 45%),
        radial-gradient(circle at 82% 78%, rgba(20,6,12,.55), transparent 50%);"
    >
    </div>
    <div class="relative mx-auto max-w-5xl px-6">
      <h1 class="animate-fade-in text-4xl font-semibold leading-tight md:text-5xl">
        {heroTitle}
      </h1>
      <p class="animate-fade-in mt-5 max-w-3xl font-serif text-xl italic text-white/85 md:text-2xl">
        {heroTagline}
      </p>
      <div class="animate-fade-in mt-10 flex flex-wrap items-center gap-x-10 gap-y-4">
        {AFFILIATIONS.map((a) => (
          <a
            href={a.href}
            target="_blank"
            rel="noopener"
            class="opacity-90 transition hover:opacity-100"
            aria-label={a.name}
            title={a.name}
          >
            <img
              src={a.logo}
              alt={a.name}
              class="h-10 w-auto md:h-12"
              loading="eager"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About — body comes from src/content/site/home.md -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h2 class="text-2xl font-semibold">About the lab</h2>
    <div class="prose-bio mt-4 max-w-3xl">
      {HomeAbout && <HomeAbout />}
    </div>
  </section>

  <!-- News -->
  <section class="bg-[color:var(--color-bg-alt)] py-16">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="text-2xl font-semibold">Recent news</h2>
      <ul class="mt-6 divide-y divide-[color:var(--color-border)]">
        {
          newsItems.map((item) => (
            <li class="grid grid-cols-1 gap-2 py-4 md:grid-cols-[110px_1fr]">
              <div class="text-sm font-semibold tracking-tight text-[color:var(--color-accent)]">
                {item.data.date}
              </div>
              <p class="m-0 text-[color:var(--color-text)]">
                {item.data.link ? (
                  <a href={item.data.link} target="_blank" rel="noopener">
                    {item.data.text}
                  </a>
                ) : (
                  item.data.text
                )}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- PI strip -->
  {pi && (
    <section class="mx-auto max-w-5xl px-6 py-16">
      <h2 class="text-2xl font-semibold">Principal Investigator</h2>
      <div class="mt-6 grid max-w-2xl gap-6 md:grid-cols-[200px_1fr]">
        <PersonCard person={pi} size="lg" />
      </div>
    </section>
  )}

  <!-- Quick links — cards come from src/content/site/home.md -->
  {exploreCards.length > 0 && (
    <section class="bg-[color:var(--color-bg-alt)] py-16">
      <div class="mx-auto grid max-w-5xl gap-4 px-6 md:grid-cols-3">
        {
          exploreCards.map((c) => (
            <a
              href={c.href}
              class="group rounded-xl border border-[color:var(--color-border)] bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md no-underline hover:no-underline"
            >
              <h3 class="text-lg font-semibold text-[color:var(--color-text)]">
                {c.title} <span class="ml-1 transition-transform group-hover:translate-x-1 inline-block">→</span>
              </h3>
              <p class="mt-1 text-sm text-[color:var(--color-text-soft)]">{c.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  )}
</Layout>
